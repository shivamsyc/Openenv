# Force trigger run 8
name: Sync to Hugging Face hub
on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  sync-to-hub:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
        with:
          fetch-depth: 0
          lfs: true
      - name: Push to hub
        run: git push -f https://shivamsyc:${{ secrets.HF_TOKEN }}@huggingface.co/spaces/shivamsyc/OpenEnv main
